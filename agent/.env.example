# Cascade voice pipeline
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Provider/model defaults
DEEPGRAM_MODEL=flux-general-en
DEEPGRAM_EAGER_EOT_THRESHOLD=0.5
DEEPGRAM_EOT_THRESHOLD=0.8
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_COMPLETION_TOKENS=180
CARTESIA_MODEL=sonic-3.5
CARTESIA_TEXT_AGGREGATION=token

# Twilio SMS confirmation (optional — if unset, SMS is logged instead of sent)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Supabase call logging (optional — if unset, call summaries are logged instead of saved)
SUPABASE_URL=
SUPABASE_KEY=

# Outbound calling / Tally webhook
# Public base URL of this server (e.g. an ngrok URL). Used to build the TwiML callback
# and WebSocket stream URL for outbound calls. Required to place outbound calls.
PUBLIC_SERVER_URL=

# Default country code prefix applied to phone numbers from Tally that don't already
# start with "+".
DEFAULT_COUNTRY_CODE=+1

# Do not place outbound demo calls to these country codes.
BLOCKED_OUTBOUND_COUNTRY_CODES=+91,+92,+977,+880

# Krisp Viva noise cancellation (optional, local only — requires a Krisp license/API key
# and a .kef model file; leave unset to run without it)
KRISP_VIVA_API_KEY=
KRISP_VIVA_FILTER_MODEL_PATH=
