# Twilio (required to place outbound calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public base URL of THIS service (e.g. https://summit-realty-webhooks.fly.dev).
# Used to build the TwiML callback URL Twilio fetches on call answer.
PUBLIC_SERVER_URL=

# Default country code prefix applied to phone numbers from Tally that don't already
# start with "+".
DEFAULT_COUNTRY_CODE=+1

# Pipecat Cloud agent + org (used to build the wss://api.pipecat.daily.co/ws/twilio
# _pipecatCloudServiceHost parameter). Must match agent_name in agent/pcc-deploy.toml
# and your Pipecat Cloud organization name.
PIPECAT_CLOUD_AGENT_NAME=summit-realty-ava
PIPECAT_CLOUD_ORGANIZATION_NAME=
